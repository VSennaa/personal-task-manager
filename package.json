{
  "name": "personal-task-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "web",
    "cli"
  ],
  "scripts": {
    "dev": "tsx watch src/api/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/src/api/server.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run --project unit",
    "pretest:integration": "tsx scripts/migrate-test-db.ts",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "user:create": "tsx scripts/user-create.ts",
    "user:password": "tsx scripts/user-password.ts"
  },
  "dependencies": {
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^10.2.1",
    "@prisma/client": "^6.2.1",
    "argon2": "^0.41.1",
    "fastify": "^5.2.0",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "dotenv": "^16.4.7",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "prisma": "^6.2.1",
    "supertest": "^7.0.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.2"
  },
  "allowScripts": {
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "argon2@0.41.1": true,
    "esbuild@0.28.1": true,
    "prisma@6.19.3": true,
    "esbuild@0.25.12": true
  }
}
