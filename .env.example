# Backend API
NODE_ENV=development
PORT=3000

# Postgres (dev)
DATABASE_URL="postgresql://taskmanager:taskmanager@localhost:5432/taskmanager?schema=public"

# Postgres (integration tests) — banco separado, resetado entre suítes
TEST_DATABASE_URL="postgresql://taskmanager:taskmanager@localhost:5433/taskmanager_test?schema=public"

# Auth
JWT_SECRET="troque-este-segredo-em-producao"
JWT_EXPIRES_IN="30d"

# Postgres (usado pelo docker-compose para criar o banco/usuário)
POSTGRES_USER=taskmanager
POSTGRES_PASSWORD=taskmanager
POSTGRES_DB=taskmanager

# Produção (docker-compose.prod.yml / Caddyfile) — domínio público via DuckDNS
DOMAIN=vsenaa.duckdns.org
